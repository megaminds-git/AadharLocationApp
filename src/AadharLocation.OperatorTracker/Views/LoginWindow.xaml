<Window x:Class="AadharLocation.OperatorTracker.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="AadharLocation Tracker — Sign In"
        Width="400" Height="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="White">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <md:BundledTheme BaseTheme="Light" PrimaryColor="Teal" SecondaryColor="Teal" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="110"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Teal header banner -->
        <Border Grid.Row="0" Background="{DynamicResource PrimaryHueMidBrush}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <md:PackIcon Kind="MapMarkerRadius"
                             Width="40" Height="40"
                             HorizontalAlignment="Center"
                             Foreground="White"/>
                <TextBlock Text="AadharLocation"
                           FontSize="20" FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,6,0,0"/>
                <TextBlock Text="Operator Tracker"
                           FontSize="12"
                           Foreground="#CCffffff"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Form card -->
        <Border Grid.Row="1" Background="White" Padding="36,28,36,28">
            <StackPanel>
                <TextBlock Text="Welcome back"
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="#1A1A2E"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4"/>
                <TextBlock Text="Sign in to continue"
                           FontSize="12"
                           Foreground="#888"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,24"/>

                <!-- Email -->
                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         md:HintAssist.Hint="Email address"
                         md:TextFieldAssist.HasLeadingIcon="True"
                         md:TextFieldAssist.LeadingIcon="Email"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,16"
                         IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}"/>

                <!-- Password -->
                <Grid Margin="0,0,0,8">
                    <PasswordBox x:Name="PasswordBox"
                                 md:HintAssist.Hint="Password"
                                 md:TextFieldAssist.HasLeadingIcon="True"
                                 md:TextFieldAssist.LeadingIcon="Lock"
                                 Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                 IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}"
                                 PasswordChanged="PasswordBox_PasswordChanged"
                                 Visibility="{Binding IsPasswordVisible, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                    <TextBox x:Name="PasswordText"
                             Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                             md:HintAssist.Hint="Password"
                             md:TextFieldAssist.HasLeadingIcon="True"
                             md:TextFieldAssist.LeadingIcon="Lock"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}"
                             Visibility="{Binding IsPasswordVisible, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <Button x:Name="TogglePasswordButton"
                            Style="{StaticResource MaterialDesignIconButton}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,4,4,0"
                            Width="32" Height="32"
                            Padding="0"
                            Click="TogglePasswordButton_Click"
                            Foreground="#888"
                            ToolTip="Show/hide password">
                        <md:PackIcon x:Name="EyeIcon" Kind="Eye" Width="18" Height="18"/>
                    </Button>
                </Grid>

                <!-- Error message -->
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"
                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,16"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

                <!-- Login button -->
                <Button Command="{Binding LoginCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        HorizontalAlignment="Stretch"
                        Height="44"
                        md:ButtonAssist.CornerRadius="6">
                    <Grid>
                        <TextBlock Text="SIGN IN"
                                   Visibility="{Binding IsBusy, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                        <ProgressBar IsIndeterminate="True"
                                     Style="{StaticResource MaterialDesignCircularProgressBar}"
                                     Width="20" Height="20"
                                     Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </Grid>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
