{
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=AadharLocationDb;Username=aadhar_user;Password=YOUR_PASS;"
  },
  "Jwt": {
    "Secret": "CHANGE_ME_TO_A_64_CHARACTER_RANDOM_SECRET_KEY_FOR_JWT_SIGNING_!!",
    "Issuer": "AadharLocation",
    "Audience": "AadharLocationClients",
    "ExpiryHours": 8
  },
  "Email": {
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": 587,
    "UseSsl": true,
    "FromAddress": "alerts@aadhar.local",
    "FromName": "AadharLocation Alerts",
    "Username": "",
    "Password": "",
    "AdminRecipients": [ "manager@company.com" ]
  },
  "Geofence": {
    "CooldownMinutes": 5
  },
  "OfflineDetection": {
    "ThresholdMinutes": 5,
    "AlertCooldownMinutes": 30
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
