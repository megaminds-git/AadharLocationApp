<Window x:Class="AadharLocation.AdminDashboard.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:AadharLocation.AdminDashboard.ViewModels"
        xmlns:infra="clr-namespace:AadharLocation.AdminDashboard.Infrastructure"
        xmlns:converters="clr-namespace:AadharLocation.AdminDashboard.Converters"
        Title="AadharLocation — Admin Dashboard"
        Height="768" Width="1280"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        FontFamily="{materialDesign:MaterialDesignFont}"
        TextElement.FontSize="13"
        Background="{DynamicResource AppBackgroundBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Converters/ConverterResources.xaml"/>
                <ResourceDictionary Source="/Styles/Buttons.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Sidebar nav item with teal left-border accent when active -->
            <Style x:Key="NavItemStyle" TargetType="RadioButton">
                <Setter Property="GroupName" Value="Nav"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Foreground" Value="{DynamicResource SidebarTextBrush}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Grid>
                                <!-- Full-width hover/selected background -->
                                <Border x:Name="Bg" Background="Transparent"/>
                                <!-- Left accent bar (3 px) -->
                                <Rectangle x:Name="LeftAccent"
                                           Width="3" HorizontalAlignment="Left"
                                           Fill="Transparent" RadiusX="2" RadiusY="2"/>
                                <!-- Nav item content — left margin accounts for accent bar -->
                                <ContentPresenter Margin="19,12,16,12" VerticalAlignment="Center"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background"
                                            Value="{DynamicResource SidebarHoverBrush}"/>
                                    <Setter Property="Foreground" Value="#E5E7EB"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Bg" Property="Background"
                                            Value="{DynamicResource SidebarSelectedBrush}"/>
                                    <Setter TargetName="LeftAccent" Property="Fill" Value="#2DD4BF"/>
                                    <Setter Property="Foreground" Value="#2DD4BF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════
             SIDEBAR
        ═══════════════════════════════════════ -->
        <DockPanel Grid.Column="0"
                   Background="{DynamicResource SidebarBackgroundBrush}"
                   LastChildFill="True">

            <!-- Brand header -->
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="16,20,16,28">
                <Border Width="36" Height="36" CornerRadius="8" Background="#1F2DD4BF">
                    <materialDesign:PackIcon Kind="MapMarkerRadius" Width="20" Height="20"
                                             Foreground="#2DD4BF"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="AadharLocation" FontSize="14" FontWeight="SemiBold"
                               Foreground="White"/>
                    <TextBlock Text="Monitoring System" FontSize="10"
                               Foreground="{DynamicResource SidebarTextBrush}"/>
                </StackPanel>
            </StackPanel>

            <!-- User footer -->
            <Border DockPanel.Dock="Bottom" Padding="12,10"
                    BorderBrush="{DynamicResource SidebarBorderBrush}" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- User avatar -->
                    <Border Grid.Column="0" Width="32" Height="32" CornerRadius="16"
                            Background="#1F2DD4BF">
                        <TextBlock Foreground="#2DD4BF" FontSize="13" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="A"/>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding UserName}" Foreground="White"
                                   FontSize="12" FontWeight="Medium"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding UserEmail}"
                                   Foreground="{DynamicResource SidebarTextBrush}"
                                   FontSize="10" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <Button Grid.Column="2"
                            Style="{StaticResource MaterialDesignIconButton}"
                            ToolTip="Logout" Command="{Binding LogoutCommand}"
                            Foreground="{DynamicResource SidebarTextBrush}">
                        <materialDesign:PackIcon Kind="Logout" Width="16" Height="16"/>
                    </Button>
                </Grid>
            </Border>

            <!-- SignalR live status -->
            <Border DockPanel.Dock="Bottom" Padding="16,6">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="6" Height="6" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#F87171"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSignalRConnected}" Value="True">
                                        <Setter Property="Fill" Value="#4ADE80"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Margin="6,0,0,0" FontSize="11"
                               Foreground="{DynamicResource SidebarTextBrush}"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Disconnected"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSignalRConnected}" Value="True">
                                        <Setter Property="Text" Value="Live"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- ── Nav items (menus unchanged per requirement) ── -->
            <StackPanel DockPanel.Dock="Top" Margin="0,4,0,0">

                <RadioButton Style="{StaticResource NavItemStyle}"
                             IsChecked="True"
                             Command="{Binding NavigateCommand}"
                             CommandParameter="{x:Static infra:NavPage.Dashboard}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ViewDashboard" Width="18" Height="18"
                                                 VerticalAlignment="Center"/>
                        <TextBlock Text="Dashboard" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </RadioButton>

                <RadioButton Style="{StaticResource NavItemStyle}"
                             Command="{Binding NavigateCommand}"
                             CommandParameter="{x:Static infra:NavPage.Operators}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AccountGroup" Width="18" Height="18"
                                                 VerticalAlignment="Center"/>
                        <TextBlock Text="Operators" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </RadioButton>

                <RadioButton Style="{StaticResource NavItemStyle}"
                             Command="{Binding NavigateCommand}"
                             CommandParameter="{x:Static infra:NavPage.Machines}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Excavator" Width="18" Height="18"
                                                 VerticalAlignment="Center"/>
                        <TextBlock Text="Machines" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </RadioButton>

                <RadioButton Style="{StaticResource NavItemStyle}"
                             Command="{Binding NavigateCommand}"
                             CommandParameter="{x:Static infra:NavPage.FleetMap}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Map" Width="18" Height="18"
                                                 VerticalAlignment="Center"/>
                        <TextBlock Text="Fleet Map" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </RadioButton>

                <RadioButton Style="{StaticResource NavItemStyle}"
                             Command="{Binding NavigateCommand}"
                             CommandParameter="{x:Static infra:NavPage.Alerts}">
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Bell" Width="18" Height="18"
                                                     VerticalAlignment="Center"/>
                            <TextBlock Text="Alerts" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                                Background="#F87171" CornerRadius="9" Padding="5,1"
                                Visibility="{Binding AlertBadgeCount,
                                    Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{Binding AlertBadgeCount}" Foreground="White"
                                       FontSize="10" FontWeight="Bold"/>
                        </Border>
                    </Grid>
                </RadioButton>

                <RadioButton Style="{StaticResource NavItemStyle}"
                             Command="{Binding NavigateCommand}"
                             CommandParameter="{x:Static infra:NavPage.Settings}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Cog" Width="18" Height="18"
                                                 VerticalAlignment="Center"/>
                        <TextBlock Text="Settings" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </RadioButton>

            </StackPanel>

        </DockPanel>

        <!-- ═══════════════════════════════════════
             MAIN CONTENT
        ═══════════════════════════════════════ -->
        <DockPanel Grid.Column="1" Background="{DynamicResource AppBackgroundBrush}">

            <!-- Top bar -->
            <Border DockPanel.Dock="Top" Height="56" Padding="24,0"
                    Background="{DynamicResource TopBarBackgroundBrush}"
                    BorderBrush="{DynamicResource TopBarBorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Page title -->
                    <TextBlock Text="{Binding CurrentPageTitle}"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               VerticalAlignment="Center"/>

                    <!-- Right-side controls -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">

                        <!-- Theme toggle -->
                        <Button x:Name="ThemeToggleButton"
                                Style="{StaticResource MaterialDesignIconButton}"
                                ToolTip="Toggle dark / light theme"
                                Click="ThemeToggle_Click"
                                Width="36" Height="36"
                                Foreground="{DynamicResource SecondaryTextBrush}">
                            <materialDesign:PackIcon x:Name="ThemeToggleIcon"
                                                     Kind="WeatherNight"
                                                     Width="18" Height="18"/>
                        </Button>

                        <!-- Refresh -->
                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                ToolTip="Refresh"
                                Width="36" Height="36" Margin="4,0,0,0"
                                Click="Refresh_Click"
                                Foreground="{DynamicResource SecondaryTextBrush}">
                            <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18"/>
                        </Button>

                    </StackPanel>
                </Grid>
            </Border>

            <!-- Page content area -->
            <ContentControl x:Name="PageContent" DockPanel.Dock="Top"/>

        </DockPanel>
    </Grid>
</Window>
