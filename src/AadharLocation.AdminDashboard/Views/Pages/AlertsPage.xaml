<UserControl x:Class="AadharLocation.AdminDashboard.Views.Pages.AlertsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:AadharLocation.AdminDashboard.Converters">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Converters/ConverterResources.xaml"/>
                <ResourceDictionary Source="/Styles/Buttons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <TextBlock Text="Alerts" FontSize="24" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Border Margin="12,0,0,0" Background="#F87171" CornerRadius="12" Padding="8,2"
                        VerticalAlignment="Center"
                        Visibility="{Binding UnacknowledgedCount, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{Binding UnacknowledgedCount}" Foreground="White"
                               FontSize="12" FontWeight="Bold"/>
                </Border>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <CheckBox Content="Unacknowledged only" Margin="0,0,12,0"
                          IsChecked="{Binding ShowUnackOnly}"
                          VerticalAlignment="Center"
                          Command="{Binding LoadCommand}"/>
                <Button Content="Acknowledge All" Margin="0,0,8,0"
                        Command="{Binding AcknowledgeAllCommand}"
                        Style="{StaticResource GhostButtonStyle}"/>
            </StackPanel>
        </Grid>

        <!-- Error message -->
        <TextBlock Grid.Row="1" Text="{Binding ErrorMessage}" Foreground="#F87171"
                   Margin="0,0,0,8"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVisibility}}"/>

        <!-- Alerts list -->
        <Border Grid.Row="2" CornerRadius="8" Background="{DynamicResource MaterialDesignPaper}"
                ClipToBounds="True">
            <DataGrid ItemsSource="{Binding Alerts}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      Style="{StaticResource MaterialDesignDataGrid}"
                      materialDesign:DataGridAssist.CellPadding="12 8 12 8">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource MaterialDesignDataGridRow}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAcknowledged}" Value="True">
                                <Setter Property="Opacity" Value="0.5"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Type" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Padding="6,2" CornerRadius="4"
                                        Background="{Binding AlertType, Converter={StaticResource AlertTypeColor}}">
                                    <TextBlock Text="{Binding AlertType}" Foreground="White"
                                               FontSize="11" FontWeight="SemiBold"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Machine"  Binding="{Binding MachineName}"  Width="*"/>
                    <DataGridTextColumn Header="Operator" Binding="{Binding OperatorName}" Width="*"/>
                    <DataGridTextColumn Header="Message"  Binding="{Binding Message}"      Width="2*"/>
                    <DataGridTextColumn Header="Time"
                                        Binding="{Binding CreatedAt, Converter={StaticResource DateTimeConverter}}"
                                        Width="150"/>
                    <DataGridTemplateColumn Header="Status" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding IsAcknowledged, Converter={StaticResource BoolToAck}}"
                                           FontSize="12">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#4ADE80"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAcknowledged}" Value="False">
                                                    <Setter Property="Foreground" Value="#FBBF24"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Ack"
                                        Padding="8,4"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        FontSize="11"
                                        Command="{Binding DataContext.AcknowledgeCommand,
                                            RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        IsEnabled="{Binding IsAcknowledged, Converter={StaticResource InverseBool}}"
                                        Visibility="{Binding IsAcknowledged,
                                            Converter={StaticResource BoolToVisibility},
                                            ConverterParameter=Inverse}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Pagination -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="←" Command="{Binding PrevPageCommand}"
                    Style="{StaticResource MaterialDesignIconButton}"/>
            <TextBlock VerticalAlignment="Center" Margin="8,0">
                <Run Text="Page "/><Run Text="{Binding CurrentPage}"/>
            </TextBlock>
            <Button Content="→" Command="{Binding NextPageCommand}"
                    Style="{StaticResource MaterialDesignIconButton}"/>
        </StackPanel>

        <!-- Loading -->
        <Grid Grid.RowSpan="4" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
              Background="#66000000">
            <ProgressBar IsIndeterminate="True" Style="{StaticResource MaterialDesignCircularProgressBar}"
                         Width="48" Height="48" HorizontalAlignment="Center" VerticalAlignment="Center"
                         Value="35"/>
        </Grid>
    </Grid>
</UserControl>
