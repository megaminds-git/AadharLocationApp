<UserControl x:Class="AadharLocation.AdminDashboard.Views.Pages.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:AadharLocation.AdminDashboard.Converters">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Converters/ConverterResources.xaml"/>
                <ResourceDictionary Source="/Styles/Buttons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── Page header ── -->
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Dashboard" FontSize="22" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                    <TextBlock Text="Real-time fleet overview" FontSize="13"
                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Refresh" Padding="14,7"
                        Command="{Binding LoadCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        VerticalAlignment="Center"/>
            </Grid>

            <!-- ── KPI cards ── -->
            <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,24">

                <!-- Total Machines -->
                <Border Margin="0,0,10,0" CornerRadius="10"
                        Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                        ClipToBounds="True">
                    <StackPanel>
                        <!-- Teal top accent -->
                        <Rectangle Height="3" Fill="{DynamicResource CardAccentTealBrush}"/>
                        <StackPanel Margin="20,16,20,20">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="38" Height="38" CornerRadius="8"
                                        Background="{DynamicResource BadgeTealBrush}">
                                    <materialDesign:PackIcon Kind="Excavator" Width="20" Height="20"
                                                             Foreground="{DynamicResource CardAccentTealBrush}"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Total Machines" Margin="10,0,0,0"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding TotalMachines}"
                                       FontSize="38" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <TextBlock Text="Fleet size"
                                       FontSize="11" Foreground="{DynamicResource TertiaryTextBrush}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Online Machines -->
                <Border Margin="5,0,5,0" CornerRadius="10"
                        Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                        ClipToBounds="True">
                    <StackPanel>
                        <Rectangle Height="3" Fill="{DynamicResource CardAccentGreenBrush}"/>
                        <StackPanel Margin="20,16,20,20">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="38" Height="38" CornerRadius="8"
                                        Background="{DynamicResource BadgeGreenBrush}">
                                    <materialDesign:PackIcon Kind="CheckCircle" Width="20" Height="20"
                                                             Foreground="{DynamicResource CardAccentGreenBrush}"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Online" Margin="10,0,0,0"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding OnlineMachines}"
                                       FontSize="38" FontWeight="Bold"
                                       Foreground="{DynamicResource CardAccentGreenBrush}"/>
                            <TextBlock Text="Active machines"
                                       FontSize="11" Foreground="{DynamicResource TertiaryTextBrush}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Offline Machines -->
                <Border Margin="5,0,5,0" CornerRadius="10"
                        Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                        ClipToBounds="True">
                    <StackPanel>
                        <Rectangle Height="3" Fill="{DynamicResource CardAccentRedBrush}"/>
                        <StackPanel Margin="20,16,20,20">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="38" Height="38" CornerRadius="8"
                                        Background="{DynamicResource BadgeRedBrush}">
                                    <materialDesign:PackIcon Kind="WifiOff" Width="20" Height="20"
                                                             Foreground="{DynamicResource CardAccentRedBrush}"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Offline" Margin="10,0,0,0"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding OfflineMachines}"
                                       FontSize="38" FontWeight="Bold"
                                       Foreground="{DynamicResource CardAccentRedBrush}"/>
                            <TextBlock Text="Need attention"
                                       FontSize="11" Foreground="{DynamicResource TertiaryTextBrush}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Unacknowledged Alerts -->
                <Border Margin="10,0,0,0" CornerRadius="10"
                        Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                        ClipToBounds="True">
                    <StackPanel>
                        <Rectangle Height="3" Fill="{DynamicResource CardAccentAmberBrush}"/>
                        <StackPanel Margin="20,16,20,20">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="38" Height="38" CornerRadius="8"
                                        Background="{DynamicResource BadgeAmberBrush}">
                                    <materialDesign:PackIcon Kind="AlertCircle" Width="20" Height="20"
                                                             Foreground="{DynamicResource CardAccentAmberBrush}"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Unack. Alerts" Margin="10,0,0,0"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding UnacknowledgedAlerts}"
                                       FontSize="38" FontWeight="Bold"
                                       Foreground="{DynamicResource CardAccentAmberBrush}"/>
                            <TextBlock Text="Require action"
                                       FontSize="11" Foreground="{DynamicResource TertiaryTextBrush}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </UniformGrid>

            <!-- ── Bottom section ── -->
            <Grid Grid.Row="2" MinHeight="300">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Recent alerts panel -->
                <Border Grid.Column="0" CornerRadius="10"
                        Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                    <DockPanel Margin="20">

                        <!-- Card header -->
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Grid.Column="0">
                                <materialDesign:PackIcon Kind="BellAlert" Width="16" Height="16"
                                                         Foreground="#F87171" VerticalAlignment="Center"/>
                                <TextBlock Text="Recent Alerts" FontSize="15" FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <!-- Separator -->
                        <Rectangle DockPanel.Dock="Top" Height="1"
                                   Fill="{DynamicResource SeparatorBrush}" Margin="0,0,0,8"/>

                        <!-- Alert list -->
                        <ListView DockPanel.Dock="Top"
                                  ItemsSource="{Binding RecentAlerts}"
                                  BorderThickness="0" Background="Transparent"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListViewItem">
                                                <ContentPresenter/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10,10" Margin="0,0,0,4" CornerRadius="6"
                                            BorderThickness="0,0,0,1"
                                            BorderBrush="{DynamicResource SeparatorBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="4"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Alert severity indicator -->
                                            <Rectangle Grid.Column="0" RadiusX="2" RadiusY="2"
                                                       Fill="#F87171" VerticalAlignment="Stretch"/>
                                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                <TextBlock Text="{Binding MachineName}"
                                                           FontWeight="SemiBold" FontSize="13"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                                                <TextBlock Text="{Binding Message}"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           FontSize="12" TextTrimming="CharacterEllipsis"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding CreatedAt,
                                                           Converter={StaticResource DateTimeConverter}}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TertiaryTextBrush}"
                                                       VerticalAlignment="Top"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <!-- Empty state -->
                        <StackPanel DockPanel.Dock="Top" HorizontalAlignment="Center"
                                    VerticalAlignment="Center" Margin="0,24,0,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RecentAlerts.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <materialDesign:PackIcon Kind="BellOff" Width="32" Height="32"
                                                     Foreground="{DynamicResource TertiaryTextBrush}"
                                                     HorizontalAlignment="Center"/>
                            <TextBlock Text="No recent alerts" FontSize="13"
                                       Foreground="{DynamicResource TertiaryTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>

                    </DockPanel>
                </Border>

                <!-- Fleet status panel -->
                <Border Grid.Column="2" CornerRadius="10"
                        Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                    <DockPanel Margin="20">

                        <!-- Card header -->
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,14">
                            <materialDesign:PackIcon Kind="Excavator" Width="16" Height="16"
                                                     Foreground="#2DD4BF" VerticalAlignment="Center"/>
                            <TextBlock Text="Fleet Status" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Separator -->
                        <Rectangle DockPanel.Dock="Top" Height="1"
                                   Fill="{DynamicResource SeparatorBrush}" Margin="0,0,0,8"/>

                        <!-- Machine list -->
                        <ListView DockPanel.Dock="Top"
                                  ItemsSource="{Binding RecentMachines}"
                                  BorderThickness="0" Background="Transparent">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListViewItem">
                                                <ContentPresenter/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,10" Margin="0,0,0,2" CornerRadius="6"
                                            BorderThickness="0,0,0,1"
                                            BorderBrush="{DynamicResource SeparatorBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Status dot -->
                                            <Ellipse Grid.Column="0" Width="9" Height="9"
                                                     Fill="{Binding Status,
                                                         Converter={StaticResource StatusColor}}"
                                                     VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="Medium" FontSize="13"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                                                <TextBlock Text="{Binding AssignedOperatorName}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding LastSeenAt,
                                                           Converter={StaticResource DateTimeConverter}}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TertiaryTextBrush}"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                    </DockPanel>
                </Border>
            </Grid>

            <!-- Loading overlay -->
            <Grid Grid.RowSpan="3"
                  Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
                  Background="#88000000">
                <ProgressBar IsIndeterminate="True"
                             Style="{StaticResource MaterialDesignCircularProgressBar}"
                             Width="48" Height="48"
                             HorizontalAlignment="Center" VerticalAlignment="Center"
                             Value="35"/>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
