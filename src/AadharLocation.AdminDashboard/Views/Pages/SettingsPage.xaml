<UserControl x:Class="AadharLocation.AdminDashboard.Views.Pages.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:AadharLocation.AdminDashboard.Converters">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Converters/ConverterResources.xaml"/>
                <ResourceDictionary Source="/Styles/Buttons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24" MaxWidth="700" HorizontalAlignment="Left">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Page header -->
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Settings" FontSize="24" FontWeight="SemiBold"/>
                <!-- Theme toggle -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="WeatherNight" Width="18" Height="18"
                                             VerticalAlignment="Center" Margin="0,0,6,0" Opacity="0.7"/>
                    <ToggleButton IsChecked="{Binding IsDarkTheme}"
                                  Command="{Binding ToggleThemeCommand}"
                                  Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                    <TextBlock Text="Dark theme" Margin="8,0,0,0" VerticalAlignment="Center" Opacity="0.7"/>
                </StackPanel>
            </Grid>

            <!-- Email settings card -->
            <Border Grid.Row="1" CornerRadius="8" Padding="24" Margin="0,0,0,16"
                    Background="{DynamicResource MaterialDesignPaper}">
                <StackPanel>
                    <TextBlock Text="Email Alerts (SMTP)" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 materialDesign:HintAssist.Hint="SMTP Host (e.g. smtp.gmail.com)"
                                 Text="{Binding SmtpHost, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,12"/>
                        <TextBox Grid.Column="2"
                                 materialDesign:HintAssist.Hint="Port"
                                 Text="{Binding SmtpPort, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,12"/>
                    </Grid>
                    <TextBox materialDesign:HintAssist.Hint="SMTP Username"
                             Text="{Binding SmtpUser, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"/>
                    <TextBox materialDesign:HintAssist.Hint="From address"
                             Text="{Binding FromAddress, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"/>
                    <TextBox materialDesign:HintAssist.Hint="Admin recipients (comma-separated)"
                             Text="{Binding AdminRecipients, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </Border>

            <!-- Timing settings card -->
            <Border Grid.Row="2" CornerRadius="8" Padding="24" Margin="0,0,0,16"
                    Background="{DynamicResource MaterialDesignPaper}">
                <StackPanel>
                    <TextBlock Text="Detection Thresholds" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Offline threshold (minutes)" Opacity="0.6" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox materialDesign:HintAssist.Hint="Default: 5"
                                     Text="{Binding OfflineThresholdMinutes, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Geofence breach cooldown (minutes)" Opacity="0.6" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox materialDesign:HintAssist.Hint="Default: 5"
                                     Text="{Binding GeofenceCooldownMinutes, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Save row -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"
                           Foreground="#2DD4BF"
                           Visibility="{Binding StatusMessage, Converter={StaticResource StringNotEmptyToVisibility}}"/>
                <Button Grid.Column="1" Content="Save Settings"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"/>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
