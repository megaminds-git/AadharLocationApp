<UserControl x:Class="AadharLocation.AdminDashboard.Views.Pages.MachinesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:AadharLocation.AdminDashboard.Converters">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Converters/ConverterResources.xaml"/>
                <ResourceDictionary Source="/Styles/Buttons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Machines" FontSize="24" FontWeight="SemiBold" VerticalAlignment="Center"
                       Foreground="{DynamicResource PrimaryTextBrush}"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="+ Add Machine" Margin="0,0,8,0"
                        Command="{Binding AddMachineCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"/>
            </StackPanel>
        </Grid>

        <!-- Table -->
        <Border Grid.Row="1" CornerRadius="8" Background="{DynamicResource MaterialDesignPaper}"
                ClipToBounds="True">
            <DataGrid ItemsSource="{Binding Machines}"
                      SelectedItem="{Binding SelectedMachine}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      Style="{StaticResource MaterialDesignDataGrid}"
                      RowHeight="44"
                      materialDesign:DataGridAssist.CellPadding="12 0 12 0"
                      materialDesign:DataGridAssist.ColumnHeaderPadding="12 14 12 14">
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell" BasedOn="{StaticResource MaterialDesignDataGridCell}">
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.Resources>
                    <Style x:Key="CellText" TargetType="TextBlock">
                        <Setter Property="VerticalAlignment" Value="Center"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name"          Binding="{Binding Name}"          Width="*"   ElementStyle="{StaticResource CellText}"/>
                    <DataGridTextColumn Header="Serial Number" Binding="{Binding SerialNumber}"  Width="140" ElementStyle="{StaticResource CellText}"/>
                    <DataGridTextColumn Header="Type"          Binding="{Binding Type}"          Width="100" ElementStyle="{StaticResource CellText}"/>
                    <DataGridTextColumn Header="Operator"      Binding="{Binding AssignedOperatorName}" Width="*" ElementStyle="{StaticResource CellText}"/>
                    <DataGridTemplateColumn Header="Status" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                            HorizontalAlignment="Left">
                                    <Ellipse Width="8" Height="8"
                                             Fill="{Binding Status, Converter={StaticResource StatusColor}}"
                                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding Status}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Last Seen"
                                        Binding="{Binding LastSeenAt, Converter={StaticResource DateTimeConverter}}"
                                        Width="150" ElementStyle="{StaticResource CellText}"/>
                    <DataGridTemplateColumn Width="130">
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="Actions" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                            HorizontalAlignment="Left">
                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                            Width="32" Height="32" Padding="4"
                                            ToolTip="Edit"
                                            Command="{Binding DataContext.EditMachineCommand,
                                                RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="Pencil" Width="18" Height="18"/>
                                    </Button>
                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                            Width="32" Height="32" Padding="4"
                                            ToolTip="Set Geofence"
                                            Command="{Binding DataContext.SetGeofenceCommand,
                                                RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="MapMarkerRadius" Width="18" Height="18"
                                                                  Foreground="#2DD4BF"/>
                                    </Button>
                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                            Width="32" Height="32" Padding="4"
                                            ToolTip="Delete" Foreground="#F87171"
                                            Command="{Binding DataContext.DeleteMachineCommand,
                                                RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="Delete" Width="18" Height="18"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Pagination + error -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#F87171"
                       VerticalAlignment="Center"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyToVisibility}}"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="←" Command="{Binding PrevPageCommand}"
                        Style="{StaticResource MaterialDesignIconButton}"/>
                <TextBlock VerticalAlignment="Center" Margin="8,0">
                    <Run Text="Page "/><Run Text="{Binding CurrentPage}"/>
                </TextBlock>
                <Button Content="→" Command="{Binding NextPageCommand}"
                        Style="{StaticResource MaterialDesignIconButton}"/>
            </StackPanel>
        </Grid>

        <!-- Loading -->
        <Grid Grid.RowSpan="3" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
              Background="#66000000">
            <ProgressBar IsIndeterminate="True" Style="{StaticResource MaterialDesignCircularProgressBar}"
                         Width="48" Height="48" HorizontalAlignment="Center" VerticalAlignment="Center"
                         Value="35"/>
        </Grid>
    </Grid>
</UserControl>
