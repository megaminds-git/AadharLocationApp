<UserControl x:Class="AadharLocation.AdminDashboard.Views.Pages.FleetMapPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mapsui="clr-namespace:Mapsui.UI.Wpf;assembly=Mapsui.UI.Wpf"
             xmlns:converters="clr-namespace:AadharLocation.AdminDashboard.Converters">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Converters/ConverterResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>

        <!-- Map -->
        <Grid Grid.Column="0">
            <mapsui:MapControl x:Name="MapControl" Margin="0"/>

            <!-- Status bar -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Left"
                        Margin="12" Background="#AA000000">
                <Border Padding="8,4" CornerRadius="4">
                    <TextBlock Text="{Binding StatusMessage}" Foreground="White" FontSize="12"
                               Visibility="{Binding StatusMessage, Converter={StaticResource BoolToVisibility}}"/>
                </Border>
            </StackPanel>

            <!-- Loading -->
            <Grid Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
                  Background="#66000000">
                <ProgressBar IsIndeterminate="True" Style="{StaticResource MaterialDesignCircularProgressBar}"
                             Width="48" Height="48" HorizontalAlignment="Center" VerticalAlignment="Center"
                             Value="35"/>
            </Grid>
        </Grid>

        <!-- Side panel -->
        <Border Grid.Column="1" Background="{DynamicResource MaterialDesignPaper}">
            <DockPanel>

                <!-- Header -->
                <StackPanel DockPanel.Dock="Top" Margin="16">
                    <TextBlock Text="Fleet Map" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Pins.Count, StringFormat='{}{0} machines tracked'}"
                               Opacity="0.6" FontSize="13"/>
                </StackPanel>

                <Separator DockPanel.Dock="Top"/>

                <!-- Machine list -->
                <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Pins}" Margin="8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,8" Margin="4,2" CornerRadius="6"
                                        Background="{DynamicResource MaterialDesignCardBackground}"
                                        Cursor="Hand">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.SelectPinCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding}"/>
                                    </Border.InputBindings>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Grid.Column="0" Width="10" Height="10"
                                                 Fill="{Binding Status, Converter={StaticResource StatusColor}}"
                                                 VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                            <TextBlock Text="{Binding MachineName}" FontWeight="Medium" FontSize="13"/>
                                            <TextBlock Text="{Binding OperatorName}"
                                                       Opacity="0.6" FontSize="11"/>
                                        </StackPanel>
                                        <materialDesign:PackIcon Grid.Column="2"
                                                                  Kind="AlertCircle" Width="16" Height="16"
                                                                  Foreground="#F87171" VerticalAlignment="Center"
                                                                  Visibility="{Binding IsWithinGeofence,
                                                                      Converter={StaticResource BoolToVisibility},
                                                                      ConverterParameter=Inverse}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Selected pin detail -->
                <Border DockPanel.Dock="Bottom" Margin="12" Padding="12" CornerRadius="8"
                        Background="{DynamicResource MaterialDesignCardBackground}"
                        Visibility="{Binding SelectedPin, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="{Binding SelectedPin.MachineName}" FontWeight="SemiBold"/>
                        <TextBlock Margin="0,4" Opacity="0.7" FontSize="12">
                            <Run Text="Lat: "/><Run Text="{Binding SelectedPin.Latitude, StringFormat=F6}"/>
                        </TextBlock>
                        <TextBlock Margin="0,0" Opacity="0.7" FontSize="12">
                            <Run Text="Lon: "/><Run Text="{Binding SelectedPin.Longitude, StringFormat=F6}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
