<Window x:Class="AadharLocation.AdminDashboard.Views.Dialogs.GeofenceEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:converters="clr-namespace:AadharLocation.AdminDashboard.Converters"
        Title="Geofence Editor"
        Height="420" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Converters/ConverterResources.xaml"/>
                <ResourceDictionary Source="/Styles/Buttons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="MapMarkerRadius" Width="22" Height="22"
                                         Foreground="#2DD4BF" VerticalAlignment="Center"/>
                <TextBlock Text="Set Geofence" FontSize="18" FontWeight="SemiBold"
                           Margin="8,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="{Binding MachineName}" Opacity="0.6" FontSize="13" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Form -->
        <StackPanel Grid.Row="1">
            <TextBlock Text="Center coordinates" Opacity="0.6" FontSize="12" Margin="0,0,0,8"/>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         materialDesign:HintAssist.Hint="Latitude"
                         Text="{Binding CenterLatitude, UpdateSourceTrigger=PropertyChanged, StringFormat=F6}"/>
                <TextBox Grid.Column="2"
                         materialDesign:HintAssist.Hint="Longitude"
                         Text="{Binding CenterLongitude, UpdateSourceTrigger=PropertyChanged, StringFormat=F6}"/>
            </Grid>

            <TextBlock Margin="0,0,0,8" Opacity="0.6" FontSize="12">
                <Run Text="Radius: "/><Run Text="{Binding RadiusMeters, StringFormat=F0}"/><Run Text=" m"/>
            </TextBlock>
            <Slider Minimum="50" Maximum="10000" Value="{Binding RadiusMeters}"
                    Style="{StaticResource MaterialDesignSlider}"
                    TickFrequency="50"
                    Margin="0,0,0,16"/>

            <!-- Existing geofence info -->
            <Border Padding="12,8" CornerRadius="6" Background="{DynamicResource MaterialDesignCardBackground}"
                    Margin="0,0,0,12"
                    Visibility="{Binding ExistingGeofence, Converter={StaticResource BoolToVisibility}}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Information" Width="16" Height="16"
                                             Foreground="#FBBF24" VerticalAlignment="Center"/>
                    <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" FontSize="12">
                        Existing geofence (<Run Text="{Binding ExistingGeofence.RadiusMeters, StringFormat=F0}"/>m)
                        will be replaced.
                    </TextBlock>
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding ErrorMessage}" Foreground="#F87171"
                       FontSize="12" TextWrapping="Wrap"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVisibility}}"/>
        </StackPanel>

        <!-- Footer -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" Content="Cancel" Style="{StaticResource GhostButtonStyle}"
                    IsCancel="True"/>
            <Button Grid.Column="3" Content="Save Geofence" Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding SaveCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"/>
        </Grid>
    </Grid>
</Window>
