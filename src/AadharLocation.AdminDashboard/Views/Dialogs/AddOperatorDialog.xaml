<Window x:Class="AadharLocation.AdminDashboard.Views.Dialogs.AddOperatorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Height="560" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource CardBackgroundBrush}"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Window.Style>
        <Style TargetType="Window">
            <Setter Property="Title" Value="Add Operator"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                    <Setter Property="Title" Value="Edit Operator"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Style>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Converters/ConverterResources.xaml"/>
                <ResourceDictionary Source="/Styles/Buttons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                <Setter Property="CaretBrush" Value="{DynamicResource BrandTealBrush}"/>
                <Setter Property="materialDesign:HintAssist.IsFloating" Value="True"/>
                <Setter Property="materialDesign:HintAssist.Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
                <Setter Property="Validation.ErrorTemplate" Value="{x:Null}"/>
                <Setter Property="Margin" Value="0,8,0,8"/>
            </Style>
            <Style TargetType="PasswordBox" BasedOn="{StaticResource MaterialDesignOutlinedPasswordBox}">
                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                <Setter Property="CaretBrush" Value="{DynamicResource BrandTealBrush}"/>
                <Setter Property="materialDesign:HintAssist.IsFloating" Value="True"/>
                <Setter Property="materialDesign:HintAssist.Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
                <Setter Property="Margin" Value="0,8,0,8"/>
            </Style>
            <Style TargetType="ComboBox" BasedOn="{StaticResource MaterialDesignOutlinedComboBox}">
                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                <Setter Property="materialDesign:HintAssist.IsFloating" Value="True"/>
                <Setter Property="materialDesign:HintAssist.Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
                <Setter Property="Margin" Value="0,8,0,8"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="28" TextElement.Foreground="{DynamicResource PrimaryTextBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" FontSize="20" FontWeight="SemiBold"
                   Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,4">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Text" Value="Add Operator"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                            <Setter Property="Text" Value="Edit Operator"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
        <TextBlock Grid.Row="1" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"
                   Margin="0,0,0,16">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Text" Value="Fields marked * are required"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                            <Setter Property="Text" Value="Update operator details"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
        <Rectangle Grid.Row="2" Height="1" Fill="{DynamicResource SeparatorBrush}" Margin="0,0,0,20"/>

        <!-- Form fields -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBox materialDesign:HintAssist.Hint="Full name *"
                         Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
                <TextBox materialDesign:HintAssist.Hint="Email address *"
                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
                <TextBox materialDesign:HintAssist.Hint="Phone number"
                         Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBox materialDesign:HintAssist.Hint="District"
                         Text="{Binding District, UpdateSourceTrigger=PropertyChanged}"/>
                <PasswordBox x:Name="PwdBox" PasswordChanged="PwdBox_PasswordChanged"
                             Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}">
                    <PasswordBox.Style>
                        <Style TargetType="PasswordBox" BasedOn="{StaticResource MaterialDesignOutlinedPasswordBox}">
                            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                            <Setter Property="CaretBrush" Value="{DynamicResource BrandTealBrush}"/>
                            <Setter Property="materialDesign:HintAssist.IsFloating" Value="True"/>
                            <Setter Property="materialDesign:HintAssist.Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
                            <Setter Property="Margin" Value="0,8,0,8"/>
                            <Setter Property="materialDesign:HintAssist.Hint" Value="Password *"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                    <Setter Property="materialDesign:HintAssist.Hint" Value="New password (leave blank to keep)"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding PasswordHasError}" Value="True">
                                    <Setter Property="BorderBrush" Value="#F87171"/>
                                    <Setter Property="materialDesign:HintAssist.Foreground" Value="#F87171"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </PasswordBox.Style>
                </PasswordBox>
                <ComboBox materialDesign:HintAssist.Hint="Status"
                          ItemsSource="{Binding Statuses}"
                          SelectedItem="{Binding Status}"
                          Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}"/>

                <TextBlock Text="{Binding ErrorMessage}" Foreground="#F87171"
                           FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyToVisibility}}"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <Grid Grid.Row="4" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" Content="Cancel" Style="{StaticResource GhostButtonStyle}"
                    IsCancel="True"/>
            <Button Grid.Column="3" Content="Save" Style="{StaticResource PrimaryButtonStyle}"
                    Click="SaveButton_Click"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"/>
        </Grid>
    </Grid>
</Window>
