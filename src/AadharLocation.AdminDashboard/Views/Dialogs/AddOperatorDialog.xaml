<Window x:Class="AadharLocation.AdminDashboard.Views.Dialogs.AddOperatorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:converters="clr-namespace:AadharLocation.AdminDashboard.Converters"
        Height="480" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Window.Style>
        <Style TargetType="Window">
            <Setter Property="Title" Value="Add Operator"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                    <Setter Property="Title" Value="Edit Operator"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Style>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/Buttons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
            <converters:InverseBoolConverter x:Key="InverseBool"/>
            <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}"/>
            <Style TargetType="ComboBox" BasedOn="{StaticResource MaterialDesignOutlinedComboBox}"/>
            <Style TargetType="PasswordBox" BasedOn="{StaticResource MaterialDesignOutlinedPasswordBox}"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,20">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Text" Value="Add Operators"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                            <Setter Property="Text" Value="Edit Operator"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBox materialDesign:HintAssist.Hint="name"
                         Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12"/>
                <TextBox materialDesign:HintAssist.Hint="email"
                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12"/>
                <TextBox materialDesign:HintAssist.Hint="phone"
                         Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12"/>
                <TextBox materialDesign:HintAssist.Hint="district"
                         Text="{Binding District, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12"/>
                <PasswordBox x:Name="PwdBox"
                             Margin="0,0,0,12">
                    <PasswordBox.Style>
                        <Style TargetType="PasswordBox" BasedOn="{StaticResource MaterialDesignOutlinedPasswordBox}">
                            <Setter Property="materialDesign:HintAssist.Hint" Value="password"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                    <Setter Property="materialDesign:HintAssist.Hint" Value="new password (leave blank to keep)"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </PasswordBox.Style>
                </PasswordBox>
                <ComboBox materialDesign:HintAssist.Hint="Status"
                          ItemsSource="{Binding Statuses}"
                          SelectedItem="{Binding Status}"
                          Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}"
                          Margin="0,0,0,12"/>

                <TextBlock Text="{Binding ErrorMessage}" Foreground="#F87171"
                           FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyToVisibility}}"/>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" Content="Cancel" Style="{StaticResource GhostButtonStyle}"
                    IsCancel="True"/>
            <Button Grid.Column="3" Content="Save" Style="{StaticResource PrimaryButtonStyle}"
                    Click="SaveButton_Click"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"/>
        </Grid>
    </Grid>
</Window>
