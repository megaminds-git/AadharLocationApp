<Window x:Class="AadharLocation.AdminDashboard.Views.Dialogs.AddMachineDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Height="460" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource CardBackgroundBrush}"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Window.Style>
        <Style TargetType="Window">
            <Setter Property="Title" Value="Add Machine"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                    <Setter Property="Title" Value="Edit Machine"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Style>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Converters/ConverterResources.xaml"/>
                <ResourceDictionary Source="/Styles/Buttons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                <Setter Property="CaretBrush" Value="{DynamicResource BrandTealBrush}"/>
                <Setter Property="materialDesign:HintAssist.IsFloating" Value="True"/>
                <Setter Property="materialDesign:HintAssist.Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
                <Setter Property="Validation.ErrorTemplate" Value="{x:Null}"/>
                <Setter Property="Margin" Value="0,8,0,8"/>
            </Style>
            <Style TargetType="ComboBox" BasedOn="{StaticResource MaterialDesignOutlinedComboBox}">
                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                <Setter Property="materialDesign:HintAssist.IsFloating" Value="True"/>
                <Setter Property="materialDesign:HintAssist.Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
                <Setter Property="Margin" Value="0,8,0,8"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="28" TextElement.Foreground="{DynamicResource PrimaryTextBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" FontSize="20" FontWeight="SemiBold"
                   Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,4">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Text" Value="Add Machine"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                            <Setter Property="Text" Value="Edit Machine"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
        <TextBlock Grid.Row="1" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"
                   Margin="0,0,0,16">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Text" Value="Fields marked * are required"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                            <Setter Property="Text" Value="Update machine details"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
        <Rectangle Grid.Row="2" Height="1" Fill="{DynamicResource SeparatorBrush}" Margin="0,0,0,20"/>

        <!-- Form fields -->
        <StackPanel Grid.Row="3">
            <TextBox materialDesign:HintAssist.Hint="Machine name *"
                     Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
            <TextBox materialDesign:HintAssist.Hint="Machine code *"
                     Text="{Binding SerialNumber, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                     IsEnabled="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
            <ComboBox materialDesign:HintAssist.Hint="Assign operator"
                      ItemsSource="{Binding AvailableOperators}"
                      SelectedItem="{Binding SelectedOperatorItem}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Height="36">
                            <!-- Unassign sentinel row -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Operator}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <materialDesign:PackIcon Kind="AccountRemoveOutline"
                                                         Width="16" Height="16"
                                                         Foreground="#9CA3AF"
                                                         VerticalAlignment="Center"
                                                         Margin="0,0,6,0"/>
                                <TextBlock Text="— Unassign operator —"
                                           Foreground="#9CA3AF"
                                           FontStyle="Italic"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <!-- Normal operator row -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Operator}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="{Binding Operator.Name}" VerticalAlignment="Center"/>
                                <TextBlock Text=" (Assigned)"
                                           Foreground="#9CA3AF"
                                           FontSize="11"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOccupied}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
                <ComboBox.ItemContainerStyle>
                    <Style TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}">
                        <Setter Property="MinHeight" Value="40"/>
                        <Setter Property="Padding" Value="12,0"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsOccupied}" Value="True">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ComboBox.ItemContainerStyle>
            </ComboBox>

            <TextBlock Text="{Binding ErrorMessage}" Foreground="#F87171"
                       FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyToVisibility}}"/>
        </StackPanel>

        <!-- Buttons -->
        <Grid Grid.Row="4" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" Content="Cancel" Style="{StaticResource GhostButtonStyle}"
                    IsCancel="True"/>
            <Button Grid.Column="3" Content="Save" Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding SaveCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"/>
        </Grid>
    </Grid>
</Window>
