<Window x:Class="AadharLocation.AdminDashboard.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="AadharLocation — Admin Login"
        Height="540" Width="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource LoginBackgroundBrush}"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Converters/ConverterResources.xaml"/>
                <ResourceDictionary Source="/Styles/Buttons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style TargetType="TextBox"
                   BasedOn="{StaticResource MaterialDesignOutlinedTextBox}"/>
            <Style TargetType="PasswordBox"
                   BasedOn="{StaticResource MaterialDesignOutlinedPasswordBox}"/>
        </ResourceDictionary>
    </Window.Resources>

    <!-- Full-window gradient tint -->
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0F172A" Offset="0"/>
                <GradientStop Color="#0E2A38" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Teal glow circle (decorative) -->
        <Ellipse Width="400" Height="400"
                 HorizontalAlignment="Left" VerticalAlignment="Bottom"
                 Margin="-160,-80,0,0" Opacity="0.07">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#2DD4BF" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- Login card -->
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="360"
                Background="{DynamicResource LoginCardBackgroundBrush}"
                BorderBrush="{DynamicResource LoginCardBorderBrush}"
                BorderThickness="1" CornerRadius="16">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.4"
                                  BlurRadius="40" ShadowDepth="0"/>
            </Border.Effect>

            <StackPanel Margin="36,32,36,32">

                <!-- Logo -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,8">
                    <Border Width="56" Height="56" CornerRadius="14"
                            Background="#1F2DD4BF" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="MapMarkerRadius"
                                                 Width="28" Height="28"
                                                 Foreground="#2DD4BF"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="AadharLocation" FontSize="20" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center"
                               Margin="0,12,0,0"/>
                    <TextBlock Text="Monitoring System" FontSize="12" Foreground="#64748B"
                               HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Divider -->
                <Rectangle Height="1" Fill="#1F334155" Margin="0,20,0,20"/>

                <TextBlock Text="Welcome back" FontSize="16" FontWeight="SemiBold"
                           Foreground="White" HorizontalAlignment="Center"
                           Margin="0,0,0,4"/>
                <TextBlock Text="Sign in to continue" FontSize="13" Foreground="#64748B"
                           HorizontalAlignment="Center" Margin="0,0,0,24"/>

                <!-- Email -->
                <TextBox x:Name="EmailBox"
                         materialDesign:HintAssist.Hint="Email address"
                         materialDesign:HintAssist.Foreground="#64748B"
                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         Foreground="White" CaretBrush="#2DD4BF"
                         Margin="0,0,0,14"
                         KeyDown="Input_KeyDown"/>

                <!-- Password -->
                <PasswordBox x:Name="PasswordBox"
                             materialDesign:HintAssist.Hint="Password"
                             materialDesign:HintAssist.Foreground="#64748B"
                             Foreground="White" CaretBrush="#2DD4BF"
                             Margin="0,0,0,8"
                             KeyDown="Input_KeyDown"/>

                <!-- Error message -->
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#F87171"
                           FontSize="12" Margin="0,0,0,12" TextWrapping="Wrap"
                           Visibility="{Binding ErrorMessage,
                               Converter={StaticResource StringNotEmptyToVisibility}}"/>

                <!-- Sign-in button -->
                <Button Style="{StaticResource PrimaryButtonStyle}"
                        Click="SignInButton_Click"
                        Height="44" Margin="0,8,0,0"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Loading" Width="18" Height="18"
                                                 Margin="0,0,8,0"
                                                 Visibility="{Binding IsBusy,
                                                     Converter={StaticResource BoolToVisibility}}">
                            <materialDesign:PackIcon.RenderTransform>
                                <RotateTransform CenterX="9" CenterY="9"/>
                            </materialDesign:PackIcon.RenderTransform>
                            <materialDesign:PackIcon.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="RenderTransform.Angle"
                                                From="0" To="360" Duration="0:0:1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </materialDesign:PackIcon.Triggers>
                        </materialDesign:PackIcon>
                        <TextBlock Text="Sign In" FontSize="14" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>

                <!-- Hint -->
                <TextBlock Text="Default: admin@aadhar.local / Admin@123"
                           Foreground="#475569" FontSize="11"
                           HorizontalAlignment="Center" Margin="0,16,0,0"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>
