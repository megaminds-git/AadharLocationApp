<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Brand accent — theme-independent -->
    <Color x:Key="BrandTealColor">#2DD4BF</Color>
    <SolidColorBrush x:Key="BrandTealBrush" Color="#2DD4BF"/>

    <!-- Status indicators — theme-independent -->
    <SolidColorBrush x:Key="StatusOnlineBrush"   Color="#4ADE80"/>
    <SolidColorBrush x:Key="StatusOfflineBrush"  Color="#F87171"/>
    <SolidColorBrush x:Key="StatusIdleBrush"     Color="#FBBF24"/>
    <SolidColorBrush x:Key="StatusActiveBrush"   Color="#4ADE80"/>
    <SolidColorBrush x:Key="StatusInactiveBrush" Color="#9CA3AF"/>

    <!-- Alert type colors — theme-independent -->
    <SolidColorBrush x:Key="AlertBreachBrush"    Color="#F87171"/>
    <SolidColorBrush x:Key="AlertOfflineBrush"   Color="#FBBF24"/>

    <!-- KPI card accent colors — theme-independent -->
    <SolidColorBrush x:Key="CardAccentTealBrush"  Color="#2DD4BF"/>
    <SolidColorBrush x:Key="CardAccentGreenBrush" Color="#4ADE80"/>
    <SolidColorBrush x:Key="CardAccentRedBrush"   Color="#F87171"/>
    <SolidColorBrush x:Key="CardAccentAmberBrush" Color="#FBBF24"/>

    <!-- Semi-transparent badge backgrounds (AARRGGBB) -->
    <SolidColorBrush x:Key="BadgeTealBrush"   Color="#262DD4BF"/>
    <SolidColorBrush x:Key="BadgeGreenBrush"  Color="#264ADE80"/>
    <SolidColorBrush x:Key="BadgeRedBrush"    Color="#26F87171"/>
    <SolidColorBrush x:Key="BadgeAmberBrush"  Color="#26FBBF24"/>

</ResourceDictionary>
