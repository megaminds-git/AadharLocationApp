<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Window / page background -->
    <SolidColorBrush x:Key="AppBackgroundBrush"       Color="#F1F5F9"/>

    <!-- Sidebar stays dark for visual identity (like VS Code, GitHub) -->
    <SolidColorBrush x:Key="SidebarBackgroundBrush"   Color="#1E293B"/>
    <SolidColorBrush x:Key="SidebarTextBrush"         Color="#94A3B8"/>
    <SolidColorBrush x:Key="SidebarSelectedBrush"     Color="#1F2DD4BF"/>
    <SolidColorBrush x:Key="SidebarHoverBrush"        Color="#14FFFFFF"/>
    <SolidColorBrush x:Key="SidebarBorderBrush"       Color="#334155"/>

    <!-- Top bar -->
    <SolidColorBrush x:Key="TopBarBackgroundBrush"    Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TopBarBorderBrush"        Color="#E2E8F0"/>

    <!-- Cards -->
    <SolidColorBrush x:Key="CardBackgroundBrush"      Color="#FFFFFF"/>
    <SolidColorBrush x:Key="CardBorderBrush"          Color="#E2E8F0"/>

    <!-- Text hierarchy -->
    <SolidColorBrush x:Key="PrimaryTextBrush"         Color="#0F172A"/>
    <SolidColorBrush x:Key="SecondaryTextBrush"       Color="#475569"/>
    <SolidColorBrush x:Key="TertiaryTextBrush"        Color="#94A3B8"/>

    <!-- Misc -->
    <SolidColorBrush x:Key="SeparatorBrush"           Color="#E2E8F0"/>

    <!-- Login -->
    <SolidColorBrush x:Key="LoginBackgroundBrush"     Color="#F1F5F9"/>
    <SolidColorBrush x:Key="LoginCardBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="LoginCardBorderBrush"     Color="#E2E8F0"/>

</ResourceDictionary>
